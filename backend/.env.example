# Artly backend — environment variables.
# Copy to .env and fill in, or export these in your shell / hosting dashboard.

# --- Supabase (optional) ----------------------------------------------------
# Set BOTH to persist ideas/categories/settings in Supabase Postgres instead of
# local JSON files. Leave them unset for the zero-setup JSON file store.
#
# Find these in your Supabase project: Settings → API.
#   SUPABASE_URL         → "Project URL"
#   SUPABASE_SERVICE_KEY → "service_role" secret key (server-side only; bypasses
#                          RLS — never expose it to the browser / frontend)
#
# When these are set, uploaded IMAGES are also stored in Supabase Storage (a
# public bucket, auto-created on startup) instead of local disk — so images
# survive restarts/redeploys on a diskless host. Included in the free tier.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Storage bucket name for images (only used when Supabase is configured).
# SUPABASE_IMAGE_BUCKET=artly-images

# --- Paths (optional) -------------------------------------------------------
# Where local data lives. When Supabase is OFF, this holds both the JSON files
# and uploaded images. When Supabase is ON, images go to Supabase Storage and
# this dir is unused for persistence.
# ARTLY_DATA_DIR=./data
# ARTLY_FRONTEND_DIST=../frontend/dist
